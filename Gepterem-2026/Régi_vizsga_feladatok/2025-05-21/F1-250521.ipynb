   "source": [
    "import quantities as pq "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "6dd7d1d1",
   "metadata": {},
   "outputs": [],
   "source": [
    "m1=pq.UncertainQuantity(4.2, pq.gram, 0.015)\n",
    "m2=pq.UncertainQuantity(3.5, pq.kg, 0.01)\n",
    "v0=pq.UncertainQuantity(1.23, pq.m/pq.s, 0.05)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "ed818dcb",
   "metadata": {},
   "outputs": [],
   "source": [
    "v=v0*(m1+m2)/m1"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "0a65f690",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "1026.23 m/s\n",
      "+/-41.97963599241708 m/s (1 sigma)\n"
     ]
    }
   ],
   "source": [
    "print(v)"
   ]
  },
